// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String?
  bio          String?
  avatarUrl    String?
  role         UserRole  @default(USER)
  credits      Int       @default(1000)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
  orders       Order[]
  settings     UserSettings?
  favorites    Favorite[]
  playlists    Playlist[]
  cartItems    CartItem[]
  socialPosts  SocialPost[]
  socialLikes  SocialPostLike[]
  socialComments SocialComment[]
  musicSubmissions MusicSubmission[]
  tapeDesigns TapeDesignPreset[]

  @@map("users")
}

model Product {
  id       String @id @default(uuid())
  userId   String 
  designId String 

  artist      String
  title       String
  genre       String?
  subGenre    String?
  format      String?
  rating      Int       @default(0)
  duration    String?
  price       Int
  description String
  image       String
  previewUrl  String?
  isPublished Boolean   @default(true)
  availability String   @default("AVAILABLE")

  user      User      @relation(fields: [userId], references: [id])
  vhsDesign VHSDesign @relation(fields: [designId], references: [id])
  track     Track?
  orders    Order[]
  favorites Favorite[]
  playlistItems PlaylistItem[]
  carouselSlides CarouselSlide[]
  exclusiveFeatures ExclusiveFeature[]
  musicSubmissions MusicSubmission[]
  cartItems CartItem[]
  socialPosts SocialPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ExclusiveFeature {
  id          String  @id @default(uuid())
  productId   String
  label       String  @default("Exclusive Premiere")
  description String?
  isActive    Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exclusive_features")
}

model Track {
  id String @id @default(uuid())

  productId String  @unique
  title     String
  audioUrl  String

  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tracks")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique

  quality       String  @default("High")
  hardwareNoise Boolean @default(true)
  crossfade     Boolean @default(false)
  theme         String  @default("dark-neon")
  volume        Float   @default(0.8)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

model Favorite {
  id        String @id @default(uuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}

model Playlist {
  id          String @id @default(uuid())
  userId      String
  name        String
  description String?

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("playlists")
}

model PlaylistItem {
  id         String @id @default(uuid())
  playlistId String
  productId  String
  position   Int    @default(0)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([playlistId, productId])
  @@map("playlist_items")
}

model CarouselSlide {
  id          String  @id @default(uuid())
  productId   String?
  title       String
  subtitle    String?
  image       String
  ctaLabel    String?
  ctaHref     String?
  position    Int     @default(0)
  isPublished Boolean @default(true)

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carousel_slides")
}

model CartItem {
  id        String @id @default(uuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

model SocialPost {
  id        String  @id @default(uuid())
  userId    String
  productId String?

  body     String
  imageUrl String?
  channel  String  @default("Listening Wall")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  likes    SocialPostLike[]
  comments SocialComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_posts")
}

model SocialPostLike {
  id     String @id @default(uuid())
  userId String
  postId String

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("social_post_likes")
}

model SocialComment {
  id     String @id @default(uuid())
  userId String
  postId String
  body   String

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_comments")
}

enum MusicSubmissionStatus {
  PENDING
  ACCEPTED
  REVISION
  REJECTED
}

model MusicSubmission {
  id        String @id @default(uuid())
  userId    String
  productId String?

  title      String
  artist     String
  genre      String?
  format     String?
  audioUrl   String
  coverUrl   String?
  note       String?
  adminNote  String?
  price      Int     @default(20)
  status     MusicSubmissionStatus @default(PENDING)
  baseColor  String?
  borderColor String?
  discColor  String?
  sideColor  String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("music_submissions")
}

model TapeDesignPreset {
  id        String  @id @default(uuid())
  userId    String
  name      String
  baseColor String
  borderColor String
  discColor String
  sideColor String
  isPublic  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tape_design_presets")
}

model VHSDesign {
  id   String @id @default(uuid())
  name String

  titleBackgroundColor String
  baseColor            String
  borderColor          String
  discColor            String
  sideColor            String

  product Product[]

  @@map("vhs_designs")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model Order {
  id        String @id @default(uuid())
  userId    String 
  productId String 

  price  Int
  status OrderStatus @default(PAID)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}
